# Rodapé — exemplo de variáveis de ambiente (cópia para .env, não commitar valores reais)
# O plugin Secrets injeta estas chaves em BuildConfig.X em tempo de build.

# Gemini (reservado pra futuro)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_ANON_KEY=eyJ...        # legacy JWT anon key (opcional/redundante)
SUPABASE_SERVICE_ROLE=eyJ...    # NUNCA usar no app — só scripts admin locais
SUPABASE_SECRET_KEY=sb_secret_xxx

# Google OAuth (Sign-In via Credential Manager)
GOOGLE_WEB_CLIENT_ID=xxxxxxxx-xxx.apps.googleusercontent.com
GOOGLE_WEB_CLIENT_SECRET=GOCSPX-xxxx
GOOGLE_ANDROID_CLIENT_ID_DEBUG=xxxxxxxx-xxx.apps.googleusercontent.com
