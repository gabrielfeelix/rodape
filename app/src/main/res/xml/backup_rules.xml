<?xml version="1.0" encoding="utf-8"?>
<!--
  Regras de auto-backup (Android <= 11, API <= 30).

  Politica: NAO fazer backup de nada. Dados sensiveis ficam:
   - Sessao Supabase Auth: SharedPreferences "auth-storage" gerenciado pelo SDK
   - Cache Room: banco local com emails, nomes, conteudo de clubes/livros
   - Mutations pendentes: fila offline (PendingMutation)
   - DataStore "rodape_prefs": preferencias de fonte/rating

  Backup automatico pra Google Drive viola privacidade (dados de outros membros
  do clube ficariam num backup pessoal). Reinstalar = re-sincronizar do Supabase
  com login fresco, que e o comportamento correto.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="."/>
    <exclude domain="database" path="."/>
    <exclude domain="file" path="."/>
    <exclude domain="root" path="."/>
</full-backup-content>
