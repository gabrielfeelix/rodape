<?xml version="1.0" encoding="utf-8"?>
<!--
  Regras de transferencia/backup (Android 12+, API 31+).

  Mesma politica do backup_rules.xml: nao incluir nada em cloud-backup nem
  em device-transfer. Sessao e cache sao re-criados via login fresco apos
  reinstalar/migrar de aparelho.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="root" path="."/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="."/>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="."/>
        <exclude domain="root" path="."/>
    </device-transfer>
</data-extraction-rules>
